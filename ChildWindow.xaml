<Window
    x:Class="Family.ChildWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Дочернее приложение"
    Width="400"
    Height="200">

    <Grid>
        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <TextBlock
                FontSize="18"
                FontWeight="Bold"
                Text="Дочернее приложение" />

            <StackPanel Margin="0,20,0,0" Orientation="Horizontal">
                <TextBlock Text="ID текущего процесса: " />
                <TextBlock Name="ChildProcessIdTextBlock" />
            </StackPanel>

        </StackPanel>
    </Grid>
</Window>